#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

branch_name=$(git branch --show-current)
if [ "$branch_name" != "main" ] && ! printf '%s\n' "$branch_name" | grep -Eq '^(feat|fix|ci|chore|docs|refactor|test)/KIN-[0-9]+-[a-z0-9]+(-[a-z0-9]+)*$'; then
    printf "\nBranch names must match <type>/KIN-<number>-<description>.\n" >&2
    exit 1
fi

if ! command -v gitleaks >/dev/null 2>&1; then
    printf "\nInstall Gitleaks before committing: brew install gitleaks\n" >&2
    exit 1
fi

if ! gitleaks git --pre-commit --staged --no-banner; then
    printf "\nGitleaks found a potential secret in staged changes.\n" >&2
    exit 1
fi

if ! make lint; then
    printf "\nRun 'make format' to fix formatting issues.\n" >&2
    exit 1
fi

if ! make python-typecheck; then
    printf "\nRun 'make python-typecheck' to inspect type errors.\n" >&2
    exit 1
fi
