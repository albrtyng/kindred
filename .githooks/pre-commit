#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

if ! make lint; then
    printf "\nRun 'make format' to fix formatting issues.\n" >&2
    exit 1
fi

if ! make python-typecheck; then
    printf "\nRun 'make python-typecheck' to inspect type errors.\n" >&2
    exit 1
fi
